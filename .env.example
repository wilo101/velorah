# Router (GitHub Project Pages): usually auto-detected from *.github.io path.
# Override if needed, e.g. VITE_ROUTER_BASENAME=/velorah
# VITE_ROUTER_BASENAME=

# Contact form — get a free key at https://web3forms.com and paste here.
# In GitHub: Settings → Secrets → Actions → VITE_WEB3FORMS_ACCESS_KEY
VITE_WEB3FORMS_ACCESS_KEY=

# If Web3Forms is empty, "Send" opens the user's mail app to this address.
VITE_CONTACT_EMAIL=you@example.com

# Optional: hero video. Put hero.mp4 in public/ and set:
# VITE_HERO_VIDEO_URL=/hero.mp4

# Legacy / optional AI (vite injects for future use)
GEMINI_API_KEY=
APP_URL=
